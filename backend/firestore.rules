rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasAllowedEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@doonschool\\.com$');
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function rawUserRole() {
      return currentUserDoc().data.role;
    }

    function normalizedRole(role) {
      return role == 'teacher' ? 'master' : role;
    }

    function isAdmin() {
      return hasAllowedEmail() && normalizedRole(rawUserRole()) == 'admin';
    }

    function isClubScopedRole() {
      return hasAllowedEmail() && normalizedRole(rawUserRole()) in ['manager', 'master'];
    }

    function clubDoc(clubId) {
      return get(/databases/$(database)/documents/clubs/$(clubId));
    }

    function managesClub(clubId) {
      return isClubScopedRole()
        && request.auth.uid in clubDoc(clubId).data.managerIds;
    }

    function isClubManager() {
      return hasAllowedEmail() && request.auth.uid in resource.data.managerIds;
    }

    function createsOnlySafeUserFields(uid) {
      return request.resource.data.email == request.auth.token.email
        && request.resource.data.email.matches('.*@doonschool\\.com$')
        && request.resource.data.role == 'student'
        && request.resource.data.keys().hasOnly([
          'name',
          'email',
          'role',
          'clubsJoined',
          'photoURL',
          'grade',
          'section',
          'house',
          'residency',
          'scheduleAudienceKey',
          'authProvider',
          'profileCompletedAt',
          'lastLoginAt',
          'updatedAt',
          'createdAt'
        ]);
    }

    function updatesOnlySafeUserFields(uid) {
      return request.resource.data.email == resource.data.email
        && request.resource.data.email.matches('.*@doonschool\\.com$')
        && request.resource.data.role == resource.data.role
        && request.resource.data.keys().hasOnly([
          'name',
          'email',
          'role',
          'clubsJoined',
          'photoURL',
          'grade',
          'section',
          'house',
          'residency',
          'scheduleAudienceKey',
          'authProvider',
          'profileCompletedAt',
          'lastLoginAt',
          'updatedAt',
          'createdAt'
        ]);
    }

    function allowsLegacyTeacherMigration(uid) {
      return resource.data.role == 'teacher'
        && request.resource.data.role == 'master'
        && request.resource.data.email == resource.data.email
        && request.resource.data.email.matches('.*@doonschool\\.com$')
        && request.resource.data.keys().hasOnly([
          'name',
          'email',
          'role',
          'clubsJoined',
          'photoURL',
          'grade',
          'section',
          'house',
          'residency',
          'scheduleAudienceKey',
          'authProvider',
          'profileCompletedAt',
          'lastLoginAt',
          'updatedAt',
          'createdAt'
        ]);
    }

    function userCanManageClub(clubId) {
      return isAdmin() || managesClub(clubId);
    }

    function eventGroupId(data) {
      return data.relatedGroupId is string && data.relatedGroupId.size() > 0
        ? data.relatedGroupId
        : data.clubId is string && data.clubId.size() > 0
          ? data.clubId
          : null;
    }

    function isClubScopedEvent(data) {
      return eventGroupId(data) != null;
    }

    function canCreateEvent() {
      return isAdmin()
        || (isClubScopedEvent(request.resource.data) && userCanManageClub(eventGroupId(request.resource.data)));
    }

    function canUpdateExistingEvent() {
      return isAdmin()
        || (
          isClubScopedEvent(resource.data)
          && isClubScopedEvent(request.resource.data)
          && eventGroupId(resource.data) == eventGroupId(request.resource.data)
          && userCanManageClub(eventGroupId(request.resource.data))
        );
    }

    match /users/{uid} {
      allow read: if hasAllowedEmail() && (uid == request.auth.uid || isAdmin());
      allow create: if hasAllowedEmail() && uid == request.auth.uid && createsOnlySafeUserFields(uid);
      allow update: if hasAllowedEmail() && uid == request.auth.uid && (updatesOnlySafeUserFields(uid) || allowsLegacyTeacherMigration(uid));
      allow delete: if false;
    }

    match /clubs/{clubId} {
      allow read: if hasAllowedEmail();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || isClubManager();

      match /memberships/{userId} {
        allow read: if hasAllowedEmail();
        allow create, delete: if false;
        allow update: if false;
      }

      match /posts/{postId} {
        allow read: if hasAllowedEmail();
        allow create: if hasAllowedEmail()
          && (
            request.resource.data.authorId == request.auth.uid
            || request.resource.data.postedByUid == request.auth.uid
          );
        allow update, delete: if hasAllowedEmail()
          && (
            resource.data.authorId == request.auth.uid
            || resource.data.postedByUid == request.auth.uid
            || isAdmin()
            || userCanManageClub(clubId)
          );
      }
    }

    match /events/{eventId} {
      allow read: if hasAllowedEmail();
      allow create: if hasAllowedEmail() && canCreateEvent();
      allow update, delete: if hasAllowedEmail() && canUpdateExistingEvent();
    }

    match /eventRsvps/{rsvpId} {
      allow read: if hasAllowedEmail() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /scheduleEntries/{entryId} {
      allow read: if hasAllowedEmail();
      allow create, update, delete: if isAdmin();
    }

    match /scheduleDatasets/{datasetId} {
      allow read: if hasAllowedEmail();
      allow create, update, delete: if isAdmin();
    }

    match /certificates/{certId} {
      allow read: if hasAllowedEmail()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
          || (
            resource.data.clubId is string
            && resource.data.clubId.size() > 0
            && userCanManageClub(resource.data.clubId)
          )
        );
      allow create, update, delete: if false;
    }

    match /inboundMessages/{messageId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /parsedAnnouncements/{announcementId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /proposedCalendarChanges/{proposalId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /changeLogs/{changeLogId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
