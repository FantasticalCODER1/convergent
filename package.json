{
  "name": "convergent",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "install:all": "npm run install:frontend && npm run install:backend",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && npm install",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:seed\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "node scripts/devBackend.mjs",
    "dev:seed": "node scripts/seedLocalDev.mjs",
    "build": "npm run build --prefix frontend",
    "typecheck": "npm run typecheck --prefix frontend",
    "lint": "node scripts/lint.mjs",
    "test": "npm run test --prefix frontend && npm run test --prefix backend",
    "test:emulators": "firebase emulators:exec --project demo-convergent --config backend/firebase.json \"node --test tests/emulator-validation.mjs\"",
    "check": "npm run typecheck && npm run build",
    "calendar:import": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/importCalendarData.ts",
    "oauth:assist": "node scripts/oauth-assist.mjs",
    "oauth:reset": "node scripts/oauth-reset.mjs"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "firebase-tools": "^14.13.0",
    "firebase-admin": "^12.4.0",
    "husky": "^9.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
